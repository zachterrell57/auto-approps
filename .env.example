# Optional Google OAuth secret for clients that require it during token exchange.
# Do not commit real secrets to source control.
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional official congressional data APIs used by Hearing Intelligence.
CONGRESS_GOV_API_KEY=
GOVINFO_API_KEY=

# Optional fallback for live hearing transcription if no OpenAI key is stored in Settings.
OPENAI_API_KEY=

# Defaults to 119 when unset.
CURRENT_CONGRESS=

# Optional OpenAI transcription model and chunk size for live hearing capture.
HEARING_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
HEARING_LIVE_CHUNK_SECONDS=60

# Optional local retention period for hearing jobs/transcripts/outputs. 0 keeps data until cleared manually.
HEARING_RETENTION_DAYS=0

# Set true only for internal QA when exporting drafts before review.
HEARING_ALLOW_UNREVIEWED_EXPORTS=false
